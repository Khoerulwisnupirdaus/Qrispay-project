# ============================================================
# Rialo QRIS Middleware — Environment Variables
# ============================================================

# Server
PORT=3001

# Xendit Sandbox API Key (get from https://dashboard.xendit.co)
XENDIT_SECRET_KEY=xnd_development_YOUR_KEY_HERE

# Xendit Webhook Verification Token
XENDIT_WEBHOOK_TOKEN=your_webhook_token_here

# Solana
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_MIDDLEWARE_PRIVATE_KEY=your_base58_private_key_here

# Program ID (must match deployed Anchor program)
PROGRAM_ID=QRiSPay1111111111111111111111111111111111111

# Exchange Rate (fallback static rate, USD to IDR * 100)
FALLBACK_EXCHANGE_RATE=1580000

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000
